# Required. Mount this to the same directory Paperless-ngx watches as /consume.
PAPERLESS_CAM_CONSUME_DIR=/consume

# Optional.
PAPERLESS_CAM_CAMERA_INDEX=0
PAPERLESS_CAM_CAMERA_WIDTH=1920
PAPERLESS_CAM_CAMERA_HEIGHT=1080
PAPERLESS_CAM_PREVIEW_WIDTH=960
PAPERLESS_CAM_BLUR_THRESHOLD=100.0
PAPERLESS_CAM_MIN_CONTOUR_AREA=50000
PAPERLESS_CAM_STAGE_DIR=/tmp/paperless-cam

# Useful on machines without a camera while testing the UI.
PAPERLESS_CAM_DEBUG_NO_CAMERA=false
