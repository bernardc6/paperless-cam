# Required to upload directly into Paperless-ngx.
PAPERLESS_URL=http://paperless-ngx:8000
PAPERLESS_TOKEN=replace-me

# Optional.
PAPERLESS_CAM_CAMERA_INDEX=0
PAPERLESS_CAM_CAMERA_WIDTH=1920
PAPERLESS_CAM_CAMERA_HEIGHT=1080
PAPERLESS_CAM_OUTPUT_DIR=./scans
PAPERLESS_CAM_TAGS=
PAPERLESS_CAM_UPLOAD_TIMEOUT_SECONDS=60

# Useful on machines without a camera while testing the UI.
PAPERLESS_CAM_DEBUG_NO_CAMERA=false
